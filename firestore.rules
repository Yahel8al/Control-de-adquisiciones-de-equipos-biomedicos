rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // MVP: acceso abierto de lectura/escritura para que el equipo pueda usar
    // el dashboard sin necesidad de iniciar sesión. Adecuado para uso interno
    // con la URL privada. Si el sitio quedará expuesto públicamente y quieres
    // más seguridad, activa Firebase Authentication y cambia estas reglas
    // por algo como: allow read, write: if request.auth != null;
    match /{document=**} {
      allow read, write: if true;
    }
  }
}
